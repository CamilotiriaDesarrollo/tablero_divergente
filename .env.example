# Tablero Divergente - plantilla de variables de entorno.
# Copia este archivo como .env.local y completa con tus llaves reales.

# --- Supabase (obligatorio) ---
# Panel de Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
# Solo servidor. NUNCA lo expongas al cliente ni lo prefijes con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- Anthropic (obligatorio para el asistente) ---
# Solo servidor.
ANTHROPIC_API_KEY=sk-ant-...
# Modelo del asistente (opcional; por defecto Sonnet actual).
ANTHROPIC_MODEL=claude-sonnet-5

# --- Marca ---
NEXT_PUBLIC_APP_NAME=Tablero Divergente

# --- Registro (app de un solo dueno) ---
# El registro esta CERRADO por defecto. Ponlo en true SOLO para crear tu cuenta
# la primera vez, y vuelve a false despues. Ademas desactiva "Allow new users to
# sign up" en Supabase (Authentication > Providers > Email).
NEXT_PUBLIC_ALLOW_SIGNUP=false

# --- Rate limit del endpoint de IA (opcional; Upstash Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Bot de Telegram (Asistente Divergente; ver BLUEPRINT-BOT.md) ---
# Token del bot (BotFather). En LOCAL usa el bot de DESARROLLO; el de produccion
# solo vive en Vercel.
TELEGRAM_BOT_TOKEN=
# Secreto aleatorio (1-256 chars) registrado en setWebhook y validado por header.
# Generalo con: openssl rand -hex 32 (o cualquier cadena larga aleatoria).
TELEGRAM_WEBHOOK_SECRET=
# Tu id numerico de Telegram (escribele a @userinfobot para obtenerlo).
TELEGRAM_OWNER_ID=
# Tu uuid en auth.users de Supabase (SQL: select id from auth.users;).
OWNER_USER_ID=
# Transcripcion de voz (console.groq.com, gratis). Opcional: STT_PROVIDER=deepgram.
GROQ_API_KEY=
STT_PROVIDER=groq
DEEPGRAM_API_KEY=
# Frenos opcionales del bot.
BOT_DAILY_LIMIT=200
BOT_MAX_HISTORY=30
