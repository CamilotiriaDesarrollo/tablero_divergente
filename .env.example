# Tablero Divergente - plantilla de variables de entorno.
# Copia este archivo como .env.local y completa con tus llaves reales.

# --- Supabase (obligatorio) ---
# Panel de Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
# Solo la usa el BOT (service_role, server-only). La web en modo dueno unico no
# la necesita. NUNCA la expongas al cliente ni la prefijes con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (obligatorio para el asistente) ---
# Solo servidor.
ANTHROPIC_API_KEY=sk-ant-...
# Modelo del asistente (opcional; por defecto Sonnet actual).
ANTHROPIC_MODEL=claude-sonnet-5

# --- Marca ---
NEXT_PUBLIC_APP_NAME=Tablero Divergente

# --- Modo dueno unico (sin login) ---
# uuid fijo del dueno: lo llevan todas las filas (web y bot). Dejalo asi.
# Requiere la migracion supabase/migrations/0004_single_owner.sql aplicada.
OWNER_USER_ID=00000000-0000-4000-8000-000000000001

# --- Rate limit del endpoint de IA (opcional; Upstash Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Bot de Telegram (Asistente Divergente; ver BLUEPRINT-BOT.md) ---
# Token del bot de PRODUCCION (BotFather). Solo vive en Vercel; en local no.
TELEGRAM_BOT_TOKEN=
# Token del bot de DESARROLLO (BotFather, un bot aparte). Solo en .env.local.
# scripts/dev-bot.ts usa SOLO este, nunca el de produccion.
TELEGRAM_BOT_TOKEN_DEV=
# Secreto aleatorio (1-256 chars) registrado en setWebhook y validado por header.
# Generalo con: openssl rand -hex 32 (o cualquier cadena larga aleatoria).
TELEGRAM_WEBHOOK_SECRET=
# Tu id numerico de Telegram (escribele a @userinfobot para obtenerlo).
TELEGRAM_OWNER_ID=
# (OWNER_USER_ID se define arriba, en "Modo dueno unico": el bot usa el mismo.)
# Transcripcion de voz (console.groq.com, gratis). Opcional: STT_PROVIDER=deepgram.
GROQ_API_KEY=
STT_PROVIDER=groq
DEEPGRAM_API_KEY=
# Frenos opcionales del bot.
BOT_DAILY_LIMIT=200
BOT_MAX_HISTORY=30
